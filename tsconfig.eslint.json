{
  "extends": "./packages/config/tsconfig/base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "preserve",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["apps/web/*"],
      "@vivah/shared": ["packages/shared/src/index.ts"],
      "@vivah/ui": ["packages/ui/src/index.ts"]
    }
  },
  "include": [
    "apps/**/*.ts",
    "apps/**/*.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "*.config.mjs"
  ],
  "exclude": ["node_modules", "dist", ".next"]
}
