{
  "name": "vivah-australia",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter @vivah/shared build && concurrently \"pnpm --filter @vivah/api dev\" \"pnpm --filter @vivah/web dev\"",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "typecheck": "pnpm --filter @vivah/shared build && pnpm --filter @vivah/ui build && pnpm -r typecheck",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@next/eslint-plugin-next": "^16.2.6",
    "@types/node": "^22.10.1",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.8"
  }
}
