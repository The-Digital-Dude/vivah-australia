{
  "extends": "@vivah/config/tsconfig/next.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../../packages/shared/src/**/*.ts",
    "../../packages/shared/src/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
