# ─────────────────────────────────────────────────────────────────────────────
# Vivah Australia — API Environment Variables
# Copy this file to .env and fill in all values before starting the server.
# Variables marked REQUIRED must be set in production.
# Variables marked OPTIONAL activate a feature when set; safe to leave empty.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development                        # development | test | production
API_PORT=4000                               # HTTP port the API listens on
API_BASE_URL=http://localhost:4000          # REQUIRED — full public URL of the API
WEB_BASE_URL=http://localhost:3000          # REQUIRED — full public URL of the web app
CORS_ORIGINS=http://localhost:3000          # REQUIRED — comma-separated allowed origins

# ── Database ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/vivah_dev   # REQUIRED

# ── Authentication / JWT ─────────────────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-at-least-32-characters   # REQUIRED (min 32 chars)
JWT_REFRESH_SECRET=replace-with-at-least-32-characters  # REQUIRED (min 32 chars)
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── Seeding (dev / CI only) ───────────────────────────────────────────────────
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMeStrong123!

# ── Media / Cloudinary ───────────────────────────────────────────────────────
# OPTIONAL — when set, media uploads go to Cloudinary; otherwise mock storage is used.
MEDIA_ACCESS_SECRET=replace-with-at-least-32-characters  # REQUIRED in production
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Security / hCaptcha ───────────────────────────────────────────────────────
# Use 0x0000000000000000000000000000000000000000 to bypass verification locally.
HCAPTCHA_SECRET=0x0000000000000000000000000000000000000000

# ── Billing / Stripe ─────────────────────────────────────────────────────────
# OPTIONAL — when set, real Stripe checkout sessions are created.
# STRIPE_WEBHOOK_SECRET is REQUIRED when STRIPE_SECRET_KEY is set.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREFIX=price_

# ── Email Provider ────────────────────────────────────────────────────────────
# Values: console (default) | sendgrid | mailgun
EMAIL_PROVIDER=console
EMAIL_FROM=noreply@vivahaustralia.com.au

# SendGrid (required when EMAIL_PROVIDER=sendgrid)
SENDGRID_API_KEY=

# Mailgun (required when EMAIL_PROVIDER=mailgun)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=

# ── SMS Provider ──────────────────────────────────────────────────────────────
# Values: console (default) | twilio
SMS_PROVIDER=console

# Twilio (required when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Push Notifications (WebPush / VAPID) ──────────────────────────────────────
# Values: console (default) | webpush
# Generate keys: npx web-push generate-vapid-keys
PUSH_PROVIDER=console
WEB_PUSH_PUBLIC_KEY=
WEB_PUSH_PRIVATE_KEY=

# ── Error Tracking ────────────────────────────────────────────────────────────
# Values: none (default) | webhook
# When set to webhook, unhandled errors POST to ERROR_TRACKING_WEBHOOK_URL.
ERROR_TRACKING_PROVIDER=none
ERROR_TRACKING_WEBHOOK_URL=

# ── Background Job Alerts ─────────────────────────────────────────────────────
# Webhook to receive alerts when a scheduled GitHub Actions job fails.
# OPTIONAL — leave empty to disable alerts.
BACKGROUND_JOB_ALERT_WEBHOOK_URL=
