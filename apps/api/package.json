{
  "name": "@vivah/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "seed": "tsx src/db/seed.ts",
    "seed:demo": "tsx src/db/seed.ts",
    "seed:reset": "tsx src/db/seed.ts --reset",
    "start": "node dist/index.js",
    "typecheck": "pnpm --filter @vivah/shared build && tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@paypal/checkout-server-sdk": "^1.0.3",
    "@vivah/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.0.0",
    "ioredis": "^5.11.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.6.3",
    "node-cache": "^5.1.2",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "stripe": "^22.2.0",
    "twilio": "^6.0.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node-cache": "^4.2.5",
    "@types/paypal__checkout-server-sdk": "^1.0.8",
    "@types/supertest": "^6.0.2",
    "@vivah/config": "workspace:*",
    "mongodb-memory-server": "^11.2.0",
    "pino-pretty": "^13.1.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2"
  }
}
